{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/bot",
      "destination": "/api/bot.js"
    },
    {
      "source": "/((?!assets/|api/).*)",
      "destination": "/index.html"
    }
  ]
}